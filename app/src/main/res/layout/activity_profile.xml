<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".profile">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="2dp"
        app:layout_constraintBottom_toTopOf="@+id/navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/username_edit3"
                android:layout_width="288dp"
                android:layout_height="37dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:inputType="text"
                android:paddingStart="10dp"
                android:text="Tirth Unadkat"
                android:textAlignment="viewStart"
                android:textColor="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView24"
                app:layout_constraintTop_toBottomOf="@+id/textView24" />

            <ImageButton
                android:id="@+id/update_button3"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/username_edit"
                app:layout_constraintStart_toEndOf="@+id/username_edit"
                app:layout_constraintTop_toTopOf="@+id/username_edit"
                app:srcCompat="@drawable/update_data" />

            <EditText
                android:id="@+id/username_edit2"
                android:layout_width="288dp"
                android:layout_height="37dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:inputType="text"
                android:paddingStart="10dp"
                android:text="Tirth Unadkat"
                android:textAlignment="viewStart"
                android:textColor="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView24"
                app:layout_constraintTop_toBottomOf="@+id/textView24" />

            <ImageButton
                android:id="@+id/update_button2"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/username_edit"
                app:layout_constraintStart_toEndOf="@+id/username_edit"
                app:layout_constraintTop_toTopOf="@+id/username_edit"
                app:srcCompat="@drawable/update_data" />

            <ImageView
                android:id="@+id/imageView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginTop="-2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/rectangle_1" />

            <Switch
                android:id="@+id/biometric"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginTop="20dp"
                android:switchMinWidth="50dp"
                android:switchPadding="-10dp"
                android:switchTextAppearance="@style/TextAppearance.AppCompat.Large"
                android:text="Biometric"
                android:textAlignment="textStart"
                android:textColor="@color/black"
                android:textSize="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/address_edit" />

            <Button
                android:id="@+id/logout"
                android:layout_width="245dp"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#F60808"
                android:scrollbarThumbHorizontal="@color/blue"
                android:scrollbarThumbVertical="@color/blue"
                android:scrollbarTrackHorizontal="@color/blue"
                android:scrollbarTrackVertical="@color/blue"
                android:text="Log Out"
                android:textColor="@color/white"
                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/biometric" />

            <ImageButton
                android:id="@+id/image_upload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#00FFFFFF"
                app:layout_constraintBottom_toBottomOf="@+id/cardView4"
                app:layout_constraintStart_toEndOf="@+id/cardView4"
                app:srcCompat="@drawable/add_image_1" />

            <TextView
                android:id="@+id/textView24"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="76dp"
                android:text="Full Name"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="@+id/imageView9"
                app:layout_constraintTop_toBottomOf="@+id/cardView4" />

            <TextView
                android:id="@+id/textView34"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Mobile Number"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="@+id/username_edit3"
                app:layout_constraintTop_toBottomOf="@+id/username_edit3" />

            <TextView
                android:id="@+id/textView35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="E-Mail"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="@+id/mobilenumber_edit"
                app:layout_constraintTop_toBottomOf="@+id/mobilenumber_edit" />

            <TextView
                android:id="@+id/textView36"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Address"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="@+id/mobilenumber_edit"
                app:layout_constraintTop_toBottomOf="@+id/email_edit" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView4"
                android:layout_width="127dp"
                android:layout_height="119dp"
                android:layout_marginStart="30dp"
                android:layout_marginTop="150dp"
                app:cardCornerRadius="150dp"
                app:layout_constraintStart_toStartOf="@+id/imageView9"
                app:layout_constraintTop_toTopOf="@+id/imageView9">

                <ImageView
                    android:id="@+id/image_add"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:scaleType="centerCrop"

                    app:srcCompat="@drawable/profic_pic4" />
            </androidx.cardview.widget.CardView>

            <EditText
                android:id="@+id/username_edit"
                android:layout_width="288dp"
                android:layout_height="37dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:hint="Enter Name"
                android:inputType="text"
                android:paddingStart="10dp"
                android:text="Tirth Unadkat"
                android:textAlignment="viewStart"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView24"
                app:layout_constraintTop_toBottomOf="@+id/textView24" />

            <EditText
                android:id="@+id/mobilenumber_edit"
                android:layout_width="288dp"
                android:layout_height="37dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:hint="Enter Number"
                android:inputType="number"
                android:maxLength="10"
                android:paddingStart="10dp"
                android:text="9265129592"
                android:textAlignment="viewStart"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView24"
                app:layout_constraintTop_toBottomOf="@+id/textView34" />

            <EditText
                android:id="@+id/email_edit"
                android:layout_width="288dp"
                android:layout_height="37dp"
                android:layout_marginTop="84dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:hint="Enter Email"
                android:inputType="textEmailAddress"
                android:paddingStart="10dp"
                android:text="tirthparesh12@gmail.com"
                android:textAlignment="viewStart"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView35"
                app:layout_constraintTop_toBottomOf="@+id/textView34" />

            <ImageButton
                android:id="@+id/update_name"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/username_edit"
                app:layout_constraintStart_toEndOf="@+id/username_edit"
                app:layout_constraintTop_toTopOf="@+id/username_edit"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/update_data" />

            <ImageButton
                android:id="@+id/update_number"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/mobilenumber_edit"
                app:layout_constraintStart_toEndOf="@+id/username_edit"
                app:layout_constraintTop_toTopOf="@+id/mobilenumber_edit"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/update_data" />

            <ImageButton
                android:id="@+id/update_email"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/email_edit"
                app:layout_constraintStart_toEndOf="@+id/username_edit"
                app:layout_constraintTop_toTopOf="@+id/email_edit"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/update_data" />

            <ImageButton
                android:id="@+id/update_address"
                android:layout_width="41dp"
                android:layout_height="45dp"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/address_edit"
                app:layout_constraintStart_toEndOf="@+id/address_edit"
                app:layout_constraintTop_toTopOf="@+id/address_edit"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/update_data" />

            <EditText
                android:id="@+id/address_edit"
                android:layout_width="304dp"
                android:layout_height="130dp"
                android:background="@drawable/round"
                android:backgroundTint="#CCCCCC"
                android:ems="10"
                android:fadeScrollbars="false"
                android:gravity="start|top"
                android:hint="Enter Address"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:paddingStart="10dp"
                android:scrollbars="vertical"
                android:text="royal-5 appt st no 3/12 blno 401 flno 4 opp ayodhya appt junction plot rajkot 360001"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="@+id/textView36"
                app:layout_constraintTop_toBottomOf="@+id/textView36" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navigation"
        android:layout_width="408dp"
        android:layout_height="70dp"
        app:backgroundTint="@color/white"
        app:itemBackground="@color/white"
        app:itemIconSize="30dp"
        app:itemIconTint="@color/bottom_nav_icon_selector"
        app:itemTextColor="@color/bottom_nav_icon_selector"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:menu="@menu/buttom_nev" >

    </com.google.android.material.bottomnavigation.BottomNavigationView>


</androidx.constraintlayout.widget.ConstraintLayout>